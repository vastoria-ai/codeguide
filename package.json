{
  "name": "codeguide",
  "version": "0.1.0",
  "description": "Codebase learning commands for Claude Code and OpenAI Codex sessions",
  "bin": {
    "codeguide": "./dist/bin/cli.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bin/cli.ts",
    "start": "node dist/bin/cli.js",
    "lint": "tsc --noEmit",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vastoria-ai/codeguide.git"
  },
  "keywords": [
    "claude-code",
    "codex",
    "ai",
    "developer-onboarding",
    "codebase",
    "mcp",
    "cli"
  ],
  "author": "Santhosh Raju",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bugs": {
    "url": "https://github.com/vastoria-ai/codeguide/issues"
  },
  "homepage": "https://github.com/vastoria-ai/codeguide#readme"
}
